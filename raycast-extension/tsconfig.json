{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@ferroscale/metal-core": ["../packages/metal-core/src/index.ts"],
      "@ferroscale/metal-core/*": ["../packages/metal-core/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
